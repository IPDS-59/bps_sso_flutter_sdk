# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.

# App name used to build SSO redirect URIs:
#   id.go.bps://<APP_NAME>-sso-internal
#   id.go.bps://<APP_NAME>-sso-eksternal
#
# Example (Presensi BPS):
#   APP_NAME=pbd
#   INTERNAL_CLIENT_ID=03340-presensimob-ak9
#   EXTERNAL_CLIENT_ID=03340-presensimob-g67
APP_NAME=your-app
INTERNAL_CLIENT_ID=your-internal-client-id
EXTERNAL_CLIENT_ID=your-external-client-id
