{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "sso: setup app id",
      "type": "shell",
      "command": "dart run tool/setup_app_id.dart",
      "options": {
        "cwd": "${workspaceFolder}/example"
      },
      "presentation": {
        "reveal": "silent",
        "panel": "shared",
        "close": true
      },
      "problemMatcher": []
    },
    {
      "label": "sso: revert app id",
      "type": "shell",
      "command": "dart run tool/setup_app_id.dart --app-name=PLACEHOLDER",
      "options": {
        "cwd": "${workspaceFolder}/example"
      },
      "presentation": {
        "reveal": "silent",
        "panel": "shared",
        "close": true
      },
      "problemMatcher": []
    }
  ]
}
